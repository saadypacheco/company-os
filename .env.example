# URL pública del sitio (sin trailing slash)
NEXT_PUBLIC_SITE_URL=https://company-os.onrender.com

# Google Analytics 4 — Measurement ID (G-XXXXXXXXXX)
NEXT_PUBLIC_GA_ID=

# Meta (Facebook) Pixel ID
NEXT_PUBLIC_META_PIXEL_ID=

# LinkedIn Insight Tag Partner ID
NEXT_PUBLIC_LINKEDIN_PARTNER_ID=

# n8n webhook para recibir formularios de contacto
# Si no está configurado, los contactos se loguean en consola del servidor
N8N_WEBHOOK_URL=
